# Root-level gitignore — SDLC Agents monorepo

# Dependencies (all agents)
**/node_modules/

# Build output (all agents)
**/dist/

# Environment files (all agents)
**/.env

# Logs
*.log
**/logs/

# OS / editor files
.DS_Store
Thumbs.db
*.swp
.vscode/settings.json
.claude/

# Orchestrator runtime files (created at runtime, not source code)
orchestrator/backend/uploads/
orchestrator/backend/*.db
