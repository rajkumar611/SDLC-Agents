# Orchestrator Backend — environment variables
# Copy this file to .env and fill in your values
# Run the backend from orchestrator/backend/ — that's where .env lives.

PORT=3010

# Agent API base URLs (defaults shown — only override if running agents on different ports)
REQUIREMENTS_AGENT_URL=http://localhost:3001
DESIGN_AGENT_URL=http://localhost:3002
QA_AGENT_URL=http://localhost:3003
DEV_AGENT_URL=http://localhost:3004
